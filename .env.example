# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://dgfradkmlelexoaayqfg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only, used by cron routes & server inserts. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Transactional email (leads, buyer/seller confirmations) AND ops alerts.
RESEND_API_KEY=re_...
# Recipient for ops/failure alerts (cron non-200, content-engine failures).
# Falls back to ADMIN_EMAIL if unset.
ALERT_EMAIL=you@firmadeal.de
ADMIN_EMAIL=you@firmadeal.de

# ── Blog automation (Vercel cron → GitHub Actions backstop) ─────────────────
# GitHub PAT the /api/cron/blog-watchdog route uses to trigger the
# seo-content.yml workflow via workflow_dispatch when a day has no post yet.
#   • Fine-grained PAT: repo = vcelkamarvin/Firmadeal, permissions =
#       Actions: Read and write  +  Metadata: Read (mandatory).
#   • Classic PAT: scopes = repo + workflow.
# Set this in the Vercel project env (Production). This is the var whose absence
# 503'd the watchdog since ~2026-06-26.
GITHUB_DISPATCH_TOKEN=github_pat_...
# Optional shared secret; if set, cron routes require Authorization: Bearer <it>.
# Vercel sends it automatically to scheduled cron invocations.
CRON_SECRET=

# ── GitHub Actions secrets (set in the repo, NOT here) ──────────────────────
# The seo-content.yml workflow needs these as repository secrets:
#   ANTHROPIC_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
#   GOOGLE_SERVICE_ACCOUNT_JSON, and (new) RESEND_API_KEY + ALERT_EMAIL for the
#   failure-alert step.
